{
  "name": "@voilab/koa-scalar",
  "version": "0.4.0",
  "description": "Koa router based on Openapi@3 and koa-scalar",
  "keywords": [
    "openapi3",
    "openapi 3",
    "openapi@3",
    "koa scalar",
    "koa router"
  ],
  "homepage": "https://www.github.com/voilab/koa-scalar#README.md",
  "bugs": {
    "url": "https://www.github.com/voilab/koa-scalar/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/voilab/koa-scalar.git"
  },
  "license": "MIT",
  "author": "Voilab SNC <opensource@voilab.ch>",
  "type": "commonjs",
  "main": "src/index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "scalar-update": "node scripts/scalar-update.js",
    "test": "jest --coverage"
  },
  "dependencies": {
    "@scalar/openapi-parser": "^0.28.7",
    "fastest-validator": "^1.19.1",
    "lodash": "^4.18.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.7",
    "babel-jest": "^30.3.0",
    "jest": "^30.4.2",
    "koa-tree-router": "^0.13.1"
  },
  "peerDependencies": {
    "koa": "^3.2.1"
  },
  "engines": {
    "node": ">=22"
  },
  "jest": {
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "rootDir": "./src",
    "roots": [
      "../tests"
    ],
    "transform": {
      "^.+\\.js$": [
        "babel-jest",
        {
          "presets": [
            [
              "@babel/preset-env",
              {
                "targets": {
                  "node": "current"
                }
              }
            ]
          ]
        }
      ]
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(@scalar|leven)/)"
    ]
  }
}
